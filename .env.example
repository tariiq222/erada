# ═══════════════════════════════════════════════════════════════
# PRODUCTION OVERRIDES — these values MUST be overridden on the server.
# Default values here are SAFE for local development only. Shipping
# the defaults to production is a P0 incident:
#   - APP_DEBUG=true leaks .env, stack traces, and server config on every 500.
#   - APP_ENV=local skips Laravel's production optimizations.
# See .github/DEPLOYMENT.md → "Production Overrides" for the full list
# (DB_SSLMODE, SESSION_DRIVER, CACHE_STORE, QUEUE_CONNECTION, ...) and
# the post-deploy verification script.
# ═══════════════════════════════════════════════════════════════
APP_ENV=production
APP_DEBUG=false

APP_NAME="منصة إرادة"
APP_KEY=
APP_URL=http://localhost:8000

# Independent application URLs. VITE_OPERATIONAL_URL is embedded at admin
# image build time; BACKEND_URL is resolved by Nginx at container startup.
ADMIN_URL=http://localhost:8080
VITE_OPERATIONAL_URL=http://localhost:8000
BACKEND_URL=http://app
ADMIN_PORT=8080

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ═══════════════════════════════════════════════════════════════
# DATABASE - PostgreSQL ONLY (SQLite is NOT supported)
# ═══════════════════════════════════════════════════════════════
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=iradah_pmo
DB_USERNAME=iradah
DB_PASSWORD=secret

# ═══════════════════════════════════════════════════════════════
# SESSION & CACHE
# ═══════════════════════════════════════════════════════════════
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Local HTTP needs a non-secure cookie.
# Production HTTPS deployments must set SESSION_SECURE_COOKIE=true and keep
# cookies HttpOnly. When the two applications use sibling subdomains and need a
# shared login, set SESSION_DOMAIN to their parent domain (for example, .example.com).
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

CACHE_STORE=redis
QUEUE_CONNECTION=redis

# ═══════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ═══════════════════════════════════════════════════════════════
# BROADCASTING & FILESYSTEM
# ═══════════════════════════════════════════════════════════════
FILESYSTEM_DISK=local

# ═══════════════════════════════════════════════════════════════
# MAIL
# ═══════════════════════════════════════════════════════════════
MAIL_MAILER=smtp

MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=postmark
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_SCHEME=
MAIL_URL=

MAIL_FROM_ADDRESS="noreply@iradah.sa"
MAIL_FROM_NAME="${APP_NAME}"

POSTMARK_TOKEN=

# ═══════════════════════════════════════════════════════════════
# AWS (if needed)
# ═══════════════════════════════════════════════════════════════
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ═══════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════
# SANCTUM — stateful SPA auth + bearer tokens
# Comma-separated host:port pairs treated as first-party origins; they get
# the XSRF-TOKEN cookie + Sanctum stateful session. APP_URL is appended
# automatically. The SPA origin must be here or auth:sanctum will 401.
# ═══════════════════════════════════════════════════════════════
# Include every browser-visible first-party SPA host (without scheme). The
# same-origin admin proxy avoids production CORS relaxation; use HTTPS origins
# and matching secure cookie/domain settings in production.
SANCTUM_STATEFUL_DOMAINS=localhost:8000,127.0.0.1:8000,localhost:5174,127.0.0.1:5174,localhost:8080,127.0.0.1:8080
# Token TTL in MINUTES (default 24h = 1440). NULL disables expiry.
SANCTUM_TOKEN_EXPIRATION=1440
# Optional prefix used to mark issued tokens (e.g. "iradah_"). Leave empty to disable.
SANCTUM_TOKEN_PREFIX=

# ═══════════════════════════════════════════════════════════════
# LOGGING — fine-tune channel stack
# LOG_DAILY_DAYS controls how many rotated daily files are retained.
# LOG_STACK lets you combine multiple channels (e.g. "daily,slack").
# ═══════════════════════════════════════════════════════════════
LOG_DAILY_DAYS=14

# ═══════════════════════════════════════════════════════════════
# SECURITY — IP whitelist for super-admin / admin routes
# Comma-separated CIDR or host lists. Disabled by default in dev.
# ═══════════════════════════════════════════════════════════════
ADMIN_IP_WHITELIST_ENABLED=false
ADMIN_IP_WHITELIST=
ADMIN_IP_WHITELIST_DEV=

# ═══════════════════════════════════════════════════════════════
# PASSWORD POLICY — applied by App\Rules\PasswordRule on user set/reset.
# Defaults match the historical (un-flagged) behavior; tighten for prod.
# ═══════════════════════════════════════════════════════════════
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_MIXED_CASE=false
PASSWORD_REQUIRE_NUMBERS=false
PASSWORD_REQUIRE_SYMBOLS=false
PASSWORD_BLOCK_COMMON=true

# ═══════════════════════════════════════════════════════════════
# LOCKOUT — login + IP tracking (config/security.php).
# SECURITY_MAX_LOGIN_ATTEMPTS / SECURITY_LOCKOUT_MINUTES act PER ACCOUNT;
# SECURITY_MAX_IP_ATTEMPTS / SECURITY_TRACKING_WINDOW act PER IP.
# ═══════════════════════════════════════════════════════════════
SECURITY_MAX_LOGIN_ATTEMPTS=5
SECURITY_LOCKOUT_MINUTES=15
SECURITY_MAX_IP_ATTEMPTS=20
SECURITY_TRACKING_WINDOW=15

# ═══════════════════════════════════════════════════════════════
# TWO-FACTOR — config/auth.php (TOTP via Laravel Fortify).
# ═══════════════════════════════════════════════════════════════
TWO_FACTOR_ENABLED=false
TWO_FACTOR_REQUIRED_ADMINS=false

# ═══════════════════════════════════════════════════════════════
# TRUSTED PROXIES — Laravel TrustProxies middleware.
# Comma-separated IPs / CIDRs (or "*" with TRUSTED_HEADERS to accept all).
# Required when terminating TLS / load-balancing in front of Laravel.
# ═══════════════════════════════════════════════════════════════
TRUSTED_PROXIES=
TRUSTED_HEADERS=

# ═══════════════════════════════════════════════════════════════
# FRONTEND — separate origin for the SPA (used by CORS + email links).
# Falls back to APP_URL when unset.
# ═══════════════════════════════════════════════════════════════
FRONTEND_URL=

# ═══════════════════════════════════════════════════════════════
# MEETINGS — config/meetings.php
# ═══════════════════════════════════════════════════════════════
MEETINGS_REMINDER_WINDOW_HOURS=24
MEETINGS_PENDING_EXPIRY_DAYS=7
MEETINGS_RECOMMENDATION_OVERDUE_GRACE_DAYS=3
MEETINGS_NOTIFICATION_POLL_INTERVAL=60

# ═══════════════════════════════════════════════════════════════
# AUDIT — config/audit.php
# ═══════════════════════════════════════════════════════════════
AUDIT_LOG_ACCESS_DENIED=true
AUDIT_LOG_LOGINS=true
AUDIT_LOG_PASSWORD=false
AUDIT_RETENTION_DAYS=365

# ═══════════════════════════════════════════════════════════════
# SCHEDULER — config/scheduler.php. Set to "true" on the single node
# that runs `php artisan schedule:run` to disable it elsewhere.
# ═══════════════════════════════════════════════════════════════
SCHEDULER_DEPLOYED=false
